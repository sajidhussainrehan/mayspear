# MongoDB
MONGODB_URI=your_mongodb_connection_string

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# NAMECHEAP PRIVATE EMAIL CONFIGURATION
# ============================================

# SMTP Settings (REQUIRED)
SMTP_HOST=mail.privateemail.com
SMTP_PORT=587
SMTP_USER=engagement@mayspear.com
SMTP_PASS=your-mailbox-password-here
SMTP_SECURE=false

# Admin email where notifications are sent
# Can be same as SMTP_USER or a different address
ADMIN_EMAIL=engagement@mayspear.com

# Environment
NODE_ENV=development
PORT=3000
